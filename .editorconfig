# EditorConfig — https://editorconfig.org
# Match the indentation conventions already used in the codebase
# so editors stop fighting each other on save.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
# Trailing spaces in Markdown are line breaks — don't strip them.
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
