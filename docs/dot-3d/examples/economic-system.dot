// Exemple : Système Économique avec Flux Financiers
// Cas d'usage : Modélisation économie avec banques, entreprises et institutions

digraph EconomicSystem {
    // === CONFIGURATION GLOBALE ===
    defaultNodeSize = 1.1;
    particlesEnabled = true;
    autoResize = true;        // Taille selon volume financier
    bloomEffect = true;       // Visualisation accumulations capitaux
    autoColors = false;       // Couleurs par secteur économique

    // === BANQUE CENTRALE ===
    CentralBank [
        label="Banque Centrale",
        geometry="Sphere",
        dimensions="{radius: 2.8}",
        particleGeneration=1000,     // Création monétaire
        maxParticleProcessing=1200,  // Capacité illimitée théorique
        color="#1565C0",
        image="https://example.com/central-bank.jpg"
    ];

    // === BANQUES COMMERCIALES ===
    CommercialBankA [
        label="Banque Commerciale A",
        geometry="Cylinder",
        dimensions="{radius: 1.8, height: 2.5}",
        particleGeneration=300,      // Crédits accordés
        maxParticleProcessing=400,   // Capacité de traitement
        color="#1976D2"
    ];

    CommercialBankB [
        label="Banque Commerciale B",
        geometry="Cylinder",
        dimensions="{radius: 1.6, height: 2.3}",
        particleGeneration=250,
        maxParticleProcessing=350,
        color="#1E88E5"
    ];

    InvestmentBank [
        label="Banque d'Investissement",
        geometry="Box",
        dimensions="{width: 2.2, height: 2.0, depth: 2.2}",
        particleGeneration=400,      // Financements complexes
        maxParticleProcessing=300,   // Goulot : analyses risques
        color="#303F9F"
    ];

    // === ENTREPRISES SECTEUR PRIMAIRE ===
    MiningCompany [
        label="Société Minière",
        geometry="Cone",
        dimensions="{radius: 1.4, height: 2.0}",
        particleGeneration=150,      // Revenus matières premières
        maxParticleProcessing=200,
        color="#8D6E63"
    ];

    AgricultureCorp [
        label="Corporation Agricole",
        geometry="Cylinder",
        dimensions="{radius: 1.2, height: 1.8}",
        particleGeneration=120,
        maxParticleProcessing=180,
        color="#689F38"
    ];

    // === ENTREPRISES SECTEUR SECONDAIRE ===
    ManufacturingA [
        label="Industrie Manufacturing A",
        geometry="Box",
        dimensions="{width: 2.0, height: 1.8, depth: 2.0}",
        particleGeneration=200,      // Production manufacturière
        maxParticleProcessing=180,   // Goulot capacité production
        color="#F57C00"
    ];

    ManufacturingB [
        label="Industrie Manufacturing B",
        geometry="Box",
        dimensions="{width: 1.8, height: 1.6, depth: 1.8}",
        particleGeneration=180,
        maxParticleProcessing=160,
        color="#FF8F00"
    ];

    TechCompany [
        label="Entreprise Tech",
        geometry="Torus",
        dimensions="{tube: 0.6, tubularSegments: 16, radialSegments: 12}",
        particleGeneration=350,      // Revenus logiciels élevés
        maxParticleProcessing=320,   // Léger goulot R&D
        color="#7B1FA2"
    ];

    // === ENTREPRISES SECTEUR TERTIAIRE ===
    RetailChain [
        label="Chaîne de Distribution",
        geometry="Cylinder",
        dimensions="{radius: 1.5, height: 2.2}",
        particleGeneration=250,      // Volume ventes
        maxParticleProcessing=300,   // Bonne capacité écoulement
        color="#388E3C"
    ];

    ServiceCompany [
        label="Société de Services",
        geometry="Sphere",
        dimensions="{radius: 1.3}",
        particleGeneration=180,
        maxParticleProcessing=220,
        color="#00796B"
    ];

    // === INSTITUTIONS PUBLIQUES ===
    Government [
        label="État/Gouvernement",
        geometry="Box",
        dimensions="{width: 2.5, height: 2.8, depth: 2.5}",
        particleGeneration=600,      // Dépenses publiques
        maxParticleProcessing=400,   // Contraintes budgétaires
        color="#C62828"
    ];

    TaxAuthority [
        label="Administration Fiscale",
        geometry="Cylinder",
        dimensions="{radius: 1.4, height: 2.0}",
        particleGeneration=0,        // Collecte seulement
        maxParticleProcessing=500,   // Grande capacité collecte
        color="#AD1457"
    ];

    // === MARCHÉS FINANCIERS ===
    StockExchange [
        label="Bourse des Valeurs",
        geometry="Torus",
        dimensions="{tube: 0.8, tubularSegments: 20, radialSegments: 15}",
        particleGeneration=800,      // Transactions intenses
        maxParticleProcessing=600,   // Volatilité = goulot
        color="#E91E63"
    ];

    CommodityMarket [
        label="Marché Matières Premières",
        geometry="Sphere",
        dimensions="{radius: 1.6}",
        particleGeneration=200,
        maxParticleProcessing=250,
        color="#FF5722"
    ];

    // === CONSOMMATEURS ===
    Households [
        label="Ménages/Consommateurs",
        geometry="Sphere",
        dimensions="{radius: 2.2}",
        particleGeneration=100,      // Épargne limitée
        maxParticleProcessing=1000,  // Grande capacité consommation
        color="#FFC107"
    ];

    // === FLUX MONÉTAIRES PRIMAIRES ===
    // Banque centrale vers système bancaire
    CentralBank -> CommercialBankA [
        label="Liquidités A",
        maxParticleFlow=400,
        particleSpeed=2.0,
        color="#1976D2",
        style="solid"
    ];

    CentralBank -> CommercialBankB [
        label="Liquidités B",
        maxParticleFlow=350,
        particleSpeed=1.9,
        color="#1E88E5",
        style="solid"
    ];

    CentralBank -> InvestmentBank [
        label="Refinancement",
        maxParticleFlow=300,
        particleSpeed=1.8,
        color="#303F9F",
        style="solid"
    ];

    // === CRÉDITS BANCAIRES ===
    // Banques vers entreprises
    CommercialBankA -> ManufacturingA [
        label="Crédit Industriel A",
        maxParticleFlow=150,
        particleSpeed=1.5,
        color="#F57C00",
        style="dashed"
    ];

    CommercialBankA -> RetailChain [
        label="Crédit Commercial",
        maxParticleFlow=120,
        particleSpeed=1.4,
        color="#388E3C",
        style="dashed"
    ];

    CommercialBankB -> ManufacturingB [
        label="Crédit Industriel B",
        maxParticleFlow=130,
        particleSpeed=1.3,
        color="#FF8F00",
        style="dashed"
    ];

    CommercialBankB -> ServiceCompany [
        label="Crédit Services",
        maxParticleFlow=100,
        particleSpeed=1.2,
        color="#00796B",
        style="dashed"
    ];

    // === FINANCEMENTS SPÉCIALISÉS ===
    InvestmentBank -> TechCompany [
        label="Financement Tech",
        maxParticleFlow=200,         // Secteur haute croissance
        particleSpeed=1.8,
        color="#7B1FA2",
        style="solid"
    ];

    InvestmentBank -> MiningCompany [
        label="Financement Minier",
        maxParticleFlow=120,
        particleSpeed=1.4,
        color="#8D6E63",
        style="solid"
    ];

    // === FLUX SECTEUR PRIMAIRE ===
    MiningCompany -> CommodityMarket [
        label="Vente Matières",
        maxParticleFlow=100,
        particleSpeed=1.6,
        color="#FF5722",
        style="solid"
    ];

    AgricultureCorp -> CommodityMarket [
        label="Vente Agricole",
        maxParticleFlow=80,
        particleSpeed=1.5,
        color="#FF5722",
        style="solid"
    ];

    // === CHAÎNE DE VALEUR INDUSTRIELLE ===
    CommodityMarket -> ManufacturingA [
        label="Approvisionnement A",
        maxParticleFlow=90,
        particleSpeed=1.3,
        color="#F57C00",
        style="dotted"
    ];

    CommodityMarket -> ManufacturingB [
        label="Approvisionnement B",
        maxParticleFlow=80,
        particleSpeed=1.2,
        color="#FF8F00",
        style="dotted"
    ];

    ManufacturingA -> RetailChain [
        label="Produits Finis A",
        maxParticleFlow=120,
        particleSpeed=1.7,
        color="#388E3C",
        style="solid"
    ];

    ManufacturingB -> RetailChain [
        label="Produits Finis B", 
        maxParticleFlow=100,
        particleSpeed=1.6,
        color="#388E3C",
        style="solid"
    ];

    // === CONSOMMATION FINALE ===
    RetailChain -> Households [
        label="Ventes Détail",
        maxParticleFlow=180,
        particleSpeed=2.2,
        color="#FFC107",
        style="solid"
    ];

    ServiceCompany -> Households [
        label="Services Consommateurs",
        maxParticleFlow=130,
        particleSpeed=1.9,
        color="#FFC107",
        style="solid"
    ];

    TechCompany -> Households [
        label="Produits Tech",
        maxParticleFlow=150,
        particleSpeed=2.0,
        color="#FFC107",
        style="solid"
    ];

    // === MARCHÉS FINANCIERS ===
    // Entreprises vers bourse
    TechCompany -> StockExchange [
        label="IPO/Actions Tech",
        maxParticleFlow=100,
        particleSpeed=2.5,          // Volatilité élevée
        color="#E91E63",
        style="dashed"
    ];

    ManufacturingA -> StockExchange [
        label="Actions Industrielles",
        maxParticleFlow=60,
        particleSpeed=1.8,
        color="#E91E63",
        style="dashed"
    ];

    // === FISCALITÉ ===
    // Tous vers administration fiscale
    TechCompany -> TaxAuthority [
        label="Impôts Sociétés Tech",
        maxParticleFlow=80,
        particleSpeed=0.8,          // Procédures lentes
        color="#AD1457",
        style="dotted"
    ];

    ManufacturingA -> TaxAuthority [
        label="Impôts Industriels A",
        maxParticleFlow=50,
        particleSpeed=0.7,
        color="#AD1457",
        style="dotted"
    ];

    ManufacturingB -> TaxAuthority [
        label="Impôts Industriels B",
        maxParticleFlow=45,
        particleSpeed=0.7,
        color="#AD1457",
        style="dotted"
    ];

    RetailChain -> TaxAuthority [
        label="Impôts Commerce",
        maxParticleFlow=60,
        particleSpeed=0.8,
        color="#AD1457",
        style="dotted"
    ];

    Households -> TaxAuthority [
        label="Impôts Ménages",
        maxParticleFlow=200,         // Volume important
        particleSpeed=0.6,           // Traitement lourd
        color="#AD1457",
        style="dotted"
    ];

    // === DÉPENSES PUBLIQUES ===
    TaxAuthority -> Government [
        label="Recettes Fiscales",
        maxParticleFlow=400,         // Consolidation
        particleSpeed=1.0,
        color="#C62828",
        style="solid"
    ];

    Government -> Households [
        label="Allocations Sociales",
        maxParticleFlow=200,
        particleSpeed=1.3,
        color="#FFC107",
        style="dashed"
    ];

    Government -> ServiceCompany [
        label="Marchés Publics",
        maxParticleFlow=150,
        particleSpeed=1.1,
        color="#00796B",
        style="dashed"
    ];

    Government -> AgricultureCorp [
        label="Subventions Agricoles",
        maxParticleFlow=80,
        particleSpeed=1.0,
        color="#689F38",
        style="dashed"
    ];

    // === ÉPARGNE ET INVESTISSEMENT ===
    Households -> CommercialBankA [
        label="Dépôts Épargne A",
        maxParticleFlow=120,
        particleSpeed=0.9,
        color="#1976D2",
        style="dotted"
    ];

    Households -> CommercialBankB [
        label="Dépôts Épargne B",
        maxParticleFlow=100,
        particleSpeed=0.9,
        color="#1E88E5",
        style="dotted"
    ];

    Households -> StockExchange [
        label="Investissements Particuliers",
        maxParticleFlow=80,
        particleSpeed=1.5,
        color="#E91E63",
        style="dotted"
    ];

    // === DIVIDENDES ET RETOURS ===
    StockExchange -> Households [
        label="Dividendes/Plus-values",
        maxParticleFlow=60,
        particleSpeed=1.2,
        color="#FFC107",
        style="dashed"
    ];

    CommercialBankA -> Households [
        label="Intérêts Épargne A",
        maxParticleFlow=30,
        particleSpeed=0.8,
        color="#FFC107",
        style="dotted"
    ];

    CommercialBankB -> Households [
        label="Intérêts Épargne B",
        maxParticleFlow=25,
        particleSpeed=0.8,
        color="#FFC107",
        style="dotted"
    ];
}

// === MÉCANISMES ÉCONOMIQUES MODÉLISÉS ===
// 1. Création monétaire : Banque centrale vers système bancaire
// 2. Multiplicateur bancaire : Banques créent crédit
// 3. Chaîne de valeur : Primaire → Secondaire → Tertiaire → Consommation
// 4. Circuit fiscal : Collecte impôts → Redistribution
// 5. Marchés financiers : Volatilité et spéculation (goulots variables)
// 6. Épargne/Investissement : Cycle capital domestique
// 7. Goulots sectoriels : Capacités limitées créent accumulations
// 8. Effet multiplicateur : Bloom effect sur nœuds stratégiques
