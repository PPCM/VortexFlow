// Exemple : Réseau de Distribution de Données
// Cas d'usage : Visualisation des flux de données entre serveurs avec simulation temps réel

digraph NetworkDistribution {
    // === CONFIGURATION GLOBALE ===
    defaultNodeSize = 1.3;
    particlesEnabled = true;
    autoResize = true;        // Taille selon connexions
    bloomEffect = true;       // Effet sur accumulation
    autoColors = false;       // Couleurs manuelles

    // === SERVEUR CENTRAL ===
    MainDataCenter [
        label="Centre de Données Principal",
        geometry="Box",
        dimensions="{width: 6.0, height: 4.0, depth: 4.0}",
        particleGeneration=300,      // 300 requêtes/minute générées
        maxParticleProcessing=280,   // Léger goulot pour créer accumulation
        color="#1976D2",
        image="https://example.com/datacenter.jpg"
    ];

    // === SERVEURS RÉGIONAUX ===
    RegionEurope [
        label="Serveur Europe",
        geometry="Cylinder",
        dimensions="{radius: 3, height: 6}",
        particleGeneration=80,       // Génère des requêtes locales
        maxParticleProcessing=180,   // Bonne capacité de traitement
        color="#388E3C"
    ];

    RegionAsia [
        label="Serveur Asie",
        geometry="Cylinder", 
        dimensions="{radius: 3, height: 6}",
        particleGeneration=100,      // Zone à forte croissance
        maxParticleProcessing=160,   // Capacité limitée
        color="#F57C00"
    ];

    RegionAmericas [
        label="Serveur Amériques",
        geometry="Cylinder",
        dimensions="{radius: 3, height: 6}",
        particleGeneration=90,
        maxParticleProcessing=200,   // Excellente capacité
        color="#7B1FA2"
    ];

    // === SERVEURS EDGE ===
    EdgeLondon [
        label="Edge Londres",
        geometry="Cone",
        dimensions="{radius: 3, height: 6}",
        particleGeneration=40,
        maxParticleProcessing=120,
        color="#4CAF50"
    ];

    EdgeTokyo [
        label="Edge Tokyo", 
        geometry="Cone",
        dimensions="{radius: 3, height: 6}",
        particleGeneration=60,       // Zone dense
        maxParticleProcessing=100,   // Risque de saturation
        color="#FF9800"
    ];

    EdgeNewYork [
        label="Edge New York",
        geometry="Cone",
        dimensions="{radius: 3, height: 6}",
        particleGeneration=50,
        maxParticleProcessing=140,
        color="#9C27B0"
    ];

    // === SERVEURS CDN ===
    CDNCluster [
        label="Cluster CDN Global",
        geometry="Torus",
        dimensions="{tube: 1.5, tubularSegments: 24, radialSegments: 8}",
        particleGeneration=0,        // Ne génère pas, seulement traite
        maxParticleProcessing=500,   // Très haute capacité
        color="#00BCD4"
    ];

    // === UTILISATEURS FINAUX ===
    EndUsers [
        label="Utilisateurs Finaux",
        geometry="Sphere",
        dimensions="{radius: 3}",
        particleGeneration=0,        // Consommateurs finaux
        maxParticleProcessing=1000,  // Capacité illimitée (abstraction)
        color="#FF5722"
    ];

    // === FLUX PRINCIPAUX ===
    // Centre vers régions - Liaison backbone haut débit
    MainDataCenter -> RegionEurope [
        label="Backbone EU",
        maxParticleFlow=120,
        particleSpeed=2.0,           // Très rapide
        color="#1565C0",
        style="solid"
    ];

    MainDataCenter -> RegionAsia [
        label="Backbone AS", 
        maxParticleFlow=110,
        particleSpeed=1.8,           // Latence transpacifique
        color="#E65100",
        style="solid"
    ];

    MainDataCenter -> RegionAmericas [
        label="Backbone AM",
        maxParticleFlow=130,
        particleSpeed=2.2,           // Excellent backbone
        color="#4A148C",
        style="solid"
    ];

    // === FLUX RÉGIONAUX ===
    // Régions vers Edge - Connexions metropolitaines
    RegionEurope -> EdgeLondon [
        label="Metro London",
        maxParticleFlow=80,
        particleSpeed=1.5,
        color="#2E7D32",
        style="dashed"
    ];

    RegionAsia -> EdgeTokyo [
        label="Metro Tokyo",
        maxParticleFlow=90,          // Forte demande
        particleSpeed=1.3,           // Congestion réseau
        color="#EF6C00",
        style="dashed"
    ];

    RegionAmericas -> EdgeNewYork [
        label="Metro NYC",
        maxParticleFlow=85,
        particleSpeed=1.6,
        color="#6A1B9A",
        style="dashed"
    ];

    // === FLUX VERS CDN ===
    // Toutes les régions alimentent le CDN
    RegionEurope -> CDNCluster [
        maxParticleFlow=60,
        particleSpeed=1.4,
        color="#00838F",
        style="dotted"
    ];

    RegionAsia -> CDNCluster [
        maxParticleFlow=70,
        particleSpeed=3,           // Plus lent depuis l'Asie
        color="#00838F", 
        style="dotted"
    ];

    RegionAmericas -> CDNCluster [
        maxParticleFlow=65,
        particleSpeed=1.5,
        color="#00838F",
        style="dotted"
    ];

    // === FLUX FINAUX ===
    // Livraison aux utilisateurs finaux
    EdgeLondon -> EndUsers [
        label="Livraison EU",
        maxParticleFlow=100,
        particleSpeed=1.8,
        color="#C62828"
    ];

    EdgeTokyo -> EndUsers [
        label="Livraison AS",
        maxParticleFlow=120,         // Forte demande asiatique
        particleSpeed=1.6,
        color="#C62828"
    ];

    EdgeNewYork -> EndUsers [
        label="Livraison AM", 
        maxParticleFlow=110,
        particleSpeed=1.9,
        color="#C62828"
    ];

    CDNCluster -> EndUsers [
        label="CDN Direct",
        maxParticleFlow=200,         // Très haut débit CDN
        particleSpeed=6,           // Optimisé pour vitesse
        color="#BF360C",
        style="solid"
    ];

    // === FLUX DE RETOUR (ANALYTICS) ===
    // Remontée des métriques et logs
    EndUsers -> MainDataCenter [
        label="Analytics",
        maxParticleFlow=50,          // Données de télémétrie
        particleSpeed=0.8,           // Moins prioritaire
        color="#424242",
        style="dotted"
    ];
}

// === POINTS D'INTÉRÊT DE CET EXEMPLE ===
// 1. Goulot d'étranglement : MainDataCenter génère plus qu'il ne traite
// 2. Risque de saturation : EdgeTokyo forte génération/faible traitement  
// 3. CDN optimisé : Très haute capacité de traitement
// 4. Différentes vitesses selon géographie
// 5. Flux bidirectionnel avec analytics
// 6. Accumulation visible avec bloom effect
// 7. Tailles automatiques selon nombre de connexions
