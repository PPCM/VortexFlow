// Exemple : Pipeline de Traitement de Données
// Cas d'usage : Workflow CI/CD avec goulots d'étranglement et parallélisation

digraph WorkflowPipeline {
    // === CONFIGURATION GLOBALE ===
    defaultNodeSize = 1.2;
    particlesEnabled = true;
    autoResize = true;        // Taille selon charge de travail
    bloomEffect = true;       // Visualisation des accumulations
    autoColors = false;       // Couleurs par étape du pipeline

    // === SOURCES DE DONNÉES ===
    CodeRepository [
        label="Dépôt Git",
        geometry="Box",
        dimensions="{width: 2.5, height: 1.8, depth: 1.5}",
        particleGeneration=150,      // Commits réguliers
        maxParticleProcessing=150,   // Traitement instantané
        color="#FF7043",
        image="https://example.com/git-repo.jpg"
    ];

    DatabaseChanges [
        label="Migrations DB",
        geometry="Cylinder",
        dimensions="{radius: 1.2, height: 2.0}",
        particleGeneration=30,       // Moins fréquent
        maxParticleProcessing=30,
        color="#5C6BC0"
    ];

    ConfigUpdates [
        label="Config Management",
        geometry="Sphere",
        dimensions="{radius: 1.0}",
        particleGeneration=50,       // Changements config
        maxParticleProcessing=50,
        color="#26A69A"
    ];

    // === BUILD ÉTAPES ===
    Linting [
        label="Analyse Code",
        geometry="Cone",
        dimensions="{radius: 0.8, height: 1.5}",
        particleGeneration=0,
        maxParticleProcessing=200,   // Rapide
        color="#66BB6A"
    ];

    UnitTests [
        label="Tests Unitaires",
        geometry="Cone",
        dimensions="{radius: 0.9, height: 1.6}",
        particleGeneration=0,
        maxParticleProcessing=120,   // Plus lent
        color="#42A5F5"
    ];

    BuildCompile [
        label="Compilation",
        geometry="Box",
        dimensions="{width: 2.0, height: 2.0, depth: 2.0}",
        particleGeneration=0,
        maxParticleProcessing=80,    // Goulot compilation
        color="#FFA726"
    ];

    // === TESTS INTÉGRATION ===
    IntegrationTests [
        label="Tests Intégration",
        geometry="Cylinder",
        dimensions="{radius: 1.5, height: 2.5}",
        particleGeneration=0,
        maxParticleProcessing=60,    // Plus lent, complexe
        color="#EF5350"
    ];

    SecurityScan [
        label="Scan Sécurité",
        geometry="Torus",
        dimensions="{tube: 0.4, tubularSegments: 12, radialSegments: 8}",
        particleGeneration=0,
        maxParticleProcessing=40,    // Très lent, goulot majeur
        color="#AB47BC"
    ];

    PerformanceTests [
        label="Tests Performance",
        geometry="Cylinder",
        dimensions="{radius: 1.3, height: 2.2}",
        particleGeneration=0,
        maxParticleProcessing=45,    // Lent également
        color="#FF7043"
    ];

    // === PACKAGING ===
    DockerBuild [
        label="Build Docker",
        geometry="Box",
        dimensions="{width: 1.8, height: 1.8, depth: 1.8}",
        particleGeneration=0,
        maxParticleProcessing=90,    // Moyennement rapide
        color="#78909C"
    ];

    ArtifactRegistry [
        label="Registry Artifacts",
        geometry="Cylinder",
        dimensions="{radius: 2.0, height: 3.0}",
        particleGeneration=0,
        maxParticleProcessing=300,   // Stockage rapide
        color="#8D6E63"
    ];

    // === DÉPLOIEMENT ===
    StagingDeploy [
        label="Déploiement Staging",
        geometry="Sphere",
        dimensions="{radius: 1.4}",
        particleGeneration=0,
        maxParticleProcessing=70,    // Déploiement modéré
        color="#4DB6AC"
    ];

    ProductionDeploy [
        label="Déploiement Production",
        geometry="Sphere",
        dimensions="{radius: 1.6}",
        particleGeneration=0,
        maxParticleProcessing=30,    // Très contrôlé, lent
        color="#FF5722"
    ];

    // === MONITORING ===
    HealthCheck [
        label="Health Monitoring",
        geometry="Torus", 
        dimensions="{tube: 0.3, tubularSegments: 10, radialSegments: 6}",
        particleGeneration=100,      // Génère métriques
        maxParticleProcessing=200,   // Traitement rapide
        color="#FFC107"
    ];

    // === FLUX PRINCIPAUX ===
    // Sources vers première étape build
    CodeRepository -> Linting [
        label="Code Changes",
        maxParticleFlow=120,
        particleSpeed=2.0,
        color="#4CAF50",
        style="solid"
    ];

    DatabaseChanges -> Linting [
        label="DB Schema",
        maxParticleFlow=25,
        particleSpeed=1.8,
        color="#3F51B5",
        style="solid"
    ];

    ConfigUpdates -> Linting [
        label="Config Files",
        maxParticleFlow=40,
        particleSpeed=1.9,
        color="#009688",
        style="solid"
    ];

    // === PIPELINE BUILD SÉQUENTIEL ===
    Linting -> UnitTests [
        label="Code Vérifié",
        maxParticleFlow=150,         // Tout passe si OK
        particleSpeed=1.5,
        color="#8BC34A",
        style="dashed"
    ];

    UnitTests -> BuildCompile [
        label="Tests OK",
        maxParticleFlow=100,         // Quelques échecs tests
        particleSpeed=1.3,
        color="#2196F3",
        style="dashed"
    ];

    // === PARALLÉLISATION TESTS ===
    // Compilation vers tests parallèles
    BuildCompile -> IntegrationTests [
        label="Build vers Tests",
        maxParticleFlow=50,          // Goulot compilation
        particleSpeed=1.2,
        color="#FF9800",
        style="solid"
    ];

    BuildCompile -> SecurityScan [
        label="Build vers Sécurité", 
        maxParticleFlow=50,
        particleSpeed=1.0,           // Scan plus lent
        color="#9C27B0",
        style="solid"
    ];

    BuildCompile -> PerformanceTests [
        label="Build vers Perf",
        maxParticleFlow=50,
        particleSpeed=1.1,
        color="#FF5722",
        style="solid"
    ];

    // === SYNCHRONISATION ===
    // Tous les tests vers packaging
    IntegrationTests -> DockerBuild [
        label="Tests Intég OK",
        maxParticleFlow=45,          // Réduction due aux échecs
        particleSpeed=1.4,
        color="#F44336",
        style="dotted"
    ];

    SecurityScan -> DockerBuild [
        label="Sécurité OK",
        maxParticleFlow=30,          // Gros goulot sécurité
        particleSpeed=0.8,           // Plus lent
        color="#E91E63",
        style="dotted"
    ];

    PerformanceTests -> DockerBuild [
        label="Performance OK",
        maxParticleFlow=35,
        particleSpeed=1.0,
        color="#FF9800",
        style="dotted"
    ];

    // === PACKAGING ET DÉPLOIEMENT ===
    DockerBuild -> ArtifactRegistry [
        label="Image Docker",
        maxParticleFlow=60,          // Résultante des tests
        particleSpeed=1.6,
        color="#607D8B",
        style="solid"
    ];

    ArtifactRegistry -> StagingDeploy [
        label="Deploy Staging",
        maxParticleFlow=50,
        particleSpeed=1.3,
        color="#00BCD4",
        style="solid"
    ];

    StagingDeploy -> ProductionDeploy [
        label="Promotion Prod",
        maxParticleFlow=25,          // Validation manuelle
        particleSpeed=0.6,           // Très contrôlé
        color="#FF5722",
        style="dashed"
    ];

    // === MONITORING ET FEEDBACK ===
    ProductionDeploy -> HealthCheck [
        label="App Deployed",
        maxParticleFlow=20,
        particleSpeed=1.8,
        color="#CDDC39",
        style="solid"
    ];

    // === BOUCLES DE RÉTROACTION ===
    // Erreurs remontent vers développement
    IntegrationTests -> CodeRepository [
        label="Bug Reports",
        maxParticleFlow=15,          // Retour d'erreurs
        particleSpeed=0.4,           // Information lente
        color="#E57373",
        style="dotted"
    ];

    SecurityScan -> CodeRepository [
        label="Vulnérabilités",
        maxParticleFlow=10,
        particleSpeed=0.3,
        color="#F48FB1",
        style="dotted"
    ];

    HealthCheck -> CodeRepository [
        label="Métriques Prod",
        maxParticleFlow=30,          // Monitoring continu
        particleSpeed=0.5,
        color="#FFF176",
        style="dotted"
    ];

    // === FLUX PARALLÈLES ALTERNATIFS ===
    // Hotfix bypass certaines étapes
    CodeRepository -> BuildCompile [
        label="Hotfix Direct",
        maxParticleFlow=20,          // Urgence, bypass tests
        particleSpeed=2.5,           // Très rapide
        color="#FF1744",
        style="dashed"
    ];

    ArtifactRegistry -> ProductionDeploy [
        label="Rollback",
        maxParticleFlow=10,          // Version précédente
        particleSpeed=1.0,
        color="#9E9E9E",
        style="dotted"
    ];
}

// === GOULOTS ET OPTIMISATIONS VISUALISÉS ===
// 1. SecurityScan : Goulot majeur (40 max processing vs 50+ flux)
// 2. BuildCompile : Goulot modéré ralentissant tout
// 3. ProductionDeploy : Très contrôlé par design
// 4. Parallélisation : Tests intégration/sécurité/perf simultanés
// 5. Synchronisation : DockerBuild attend tous les tests
// 6. Feedback loops : Erreurs remontent vers développement
// 7. Hotfix path : Bypass pour urgences
// 8. Accumulation visible : Bloom effect sur goulots
