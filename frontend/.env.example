# Frontend environment — Vite-exposed variables
# Copy this file to frontend/.env and adjust for your local stack.
# Only variables prefixed with VITE_ are exposed to the browser.

# Backend REST API base URL (used by services/api.ts).
VITE_API_URL=http://localhost:5000/api

# WebSocket URL (Socket.IO is served by the backend on the same port as the REST API).
VITE_WS_URL=http://localhost:5000
