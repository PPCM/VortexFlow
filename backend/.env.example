# VortexFlow Backend — environment template
# Copy to `backend/.env` and fill in real values.
# Do NOT commit the populated `.env` file (it is gitignored).

# =====================================
# Runtime
# =====================================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# =====================================
# PostgreSQL
# =====================================
# Either provide a full DATABASE_URL, or set the individual DB_* values below.
# DATABASE_URL=postgres://user:password@host:5432/dbname
DB_NAME=vortexflow
DB_USER=vortexflow_user
DB_PASSWORD=change-me-in-production-please
DB_HOST=localhost
DB_PORT=5432

# =====================================
# Redis (session store)
# =====================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =====================================
# Sessions
# =====================================
# SESSION_SECRET MUST be a long random string in production.
# Example to generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=replace-with-a-long-random-string
SESSION_NAME=vortexflow-session
# Session sliding-expiration window in milliseconds (clamped to >= 1h server-side).
SESSION_MAX_AGE=86400000

# =====================================
# Default admin user (seeded on first boot if none exists)
# =====================================
# These values are PUBLIC because they live in this example file. They are
# explicitly REFUSED in production by `utils/setup.js` — set real values in
# `backend/.env` before deploying.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production-please

# =====================================
# CORS / frontend
# =====================================
FRONTEND_URL=http://localhost:3000

# =====================================
# Rate limiting (global /api limiter)
# =====================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================
# Logging
# =====================================
LOG_LEVEL=info
