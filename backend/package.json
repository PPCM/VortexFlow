{
  "name": "vortexflow-backend",
  "version": "1.0.0",
  "description": "VortexFlow Backend API - 3D DOT Graph Visualization with Data Flow Simulation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:env": "node -r dotenv/config server.js",
    "dev": "nodemon server.js",
    "dev:env": "nodemon -r dotenv/config server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "setup-db": "node scripts/setup-database.js",
    "check-db": "node -e \"require('./src/models').sequelize.authenticate().then(() => console.log('DB OK')).catch(() => process.exit(1))\"",
    "seed": "node scripts/seed-data.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "docs": "jsdoc -c jsdoc.config.json"
  },
  "keywords": [
    "3d-visualization",
    "dot-graphics",
    "data-flow-simulation",
    "three-js",
    "graphviz",
    "web-application"
  ],
  "author": "VortexFlow Team",
  "license": "MIT",
  "dependencies": {
    "archiver": "^5.3.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "cron": "^2.4.0",
    "d3-force": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "graphology": "^0.25.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.11.1",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.7",
    "sequelize": "^6.32.1",
    "sharp": "^0.32.1",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^8.44.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.6.1",
    "jsdoc": "^4.0.2",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/**",
      "!src/migrations/**",
      "!src/seeders/**"
    ],
    "verbose": true
  }
}
