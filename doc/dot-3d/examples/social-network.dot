// Exemple : Propagation d'Information dans Réseau Social
// Cas d'usage : Diffusion virale de contenu avec influenceurs et communautés

digraph SocialNetwork {
    // === CONFIGURATION GLOBALE ===
    defaultNodeSize = 1.0;
    particlesEnabled = true;
    autoResize = true;        // Taille selon nombre de followers
    bloomEffect = true;       // Visualisation viralité
    autoColors = false;       // Couleurs par type d'utilisateur

    // === INFLUENCEURS MAJEURS ===
    MegaInfluencer [
        label="Méga-Influenceur",
        geometry="Sphere",
        dimensions="{radius: 2.5}",
        particleGeneration=1000,     // Crée beaucoup de contenu
        maxParticleProcessing=800,   // Léger goulot pour accumulation
        color="#E91E63",
        image="https://example.com/mega-influencer.jpg"
    ];

    TechInfluencerA [
        label="Tech Influencer A",
        geometry="Cylinder",
        dimensions="{radius: 1.8, height: 2.2}",
        particleGeneration=400,      // Contenu spécialisé tech
        maxParticleProcessing=350,
        color="#2196F3"
    ];

    TechInfluencerB [
        label="Tech Influencer B",
        geometry="Cylinder", 
        dimensions="{radius: 1.6, height: 2.0}",
        particleGeneration=320,
        maxParticleProcessing=300,
        color="#3F51B5"
    ];

    LifestyleInfluencer [
        label="Lifestyle Influencer",
        geometry="Cone",
        dimensions="{radius: 1.4, height: 2.5}",
        particleGeneration=600,      // Contenu lifestyle viral
        maxParticleProcessing=500,
        color="#FF9800"
    ];

    // === COMMUNAUTÉS THÉMATIQUES ===
    TechCommunity [
        label="Communauté Tech",
        geometry="Torus",
        dimensions="{tube: 0.6, tubularSegments: 16, radialSegments: 12}",
        particleGeneration=200,      // Discussions communautaires
        maxParticleProcessing=400,   // Bonne capacité absorption
        color="#4CAF50"
    ];

    StartupCommunity [
        label="Communauté Startup",
        geometry="Box",
        dimensions="{width: 2.0, height: 1.8, depth: 2.0}",
        particleGeneration=150,
        maxParticleProcessing=300,
        color="#795548"
    ];

    DesignCommunity [
        label="Communauté Design",
        geometry="Torus",
        dimensions="{tube: 0.5, tubularSegments: 12, radialSegments: 10}",
        particleGeneration=180,
        maxParticleProcessing=350,
        color="#9C27B0"
    ];

    GameCommunity [
        label="Communauté Gaming",
        geometry="Box",
        dimensions="{width: 2.2, height: 2.0, depth: 1.8}",
        particleGeneration=300,      // Contenu gaming très viral
        maxParticleProcessing=250,   // Goulot volontaire
        color="#FF5722"
    ];

    // === RELAYEURS MOYENS ===
    MicroInfluencerA [
        label="Micro-Influenceur A",
        geometry="Sphere",
        dimensions="{radius: 1.0}",
        particleGeneration=80,
        maxParticleProcessing=120,
        color="#00BCD4"
    ];

    MicroInfluencerB [
        label="Micro-Influenceur B",
        geometry="Sphere",
        dimensions="{radius: 0.9}",
        particleGeneration=70,
        maxParticleProcessing=110,
        color="#607D8B"
    ];

    CompanyAccount [
        label="Compte Entreprise",
        geometry="Cylinder",
        dimensions="{radius: 1.2, height: 1.5}",
        particleGeneration=100,      // Contenu marketing
        maxParticleProcessing=200,   // Bonne capacité
        color="#8BC34A"
    ];

    // === AUDIENCE GÉNÉRALE ===
    GeneralAudience [
        label="Audience Générale",
        geometry="Sphere",
        dimensions="{radius: 3.0}",
        particleGeneration=50,       // Peu de création originale
        maxParticleProcessing=2000,  // Très grande capacité consommation
        color="#FFC107"
    ];

    // === ALGORITHMES DE RECOMMANDATION ===
    RecommendationEngine [
        label="Algorithme Recommandation",
        geometry="Box",
        dimensions="{width: 2.5, height: 2.5, depth: 2.5}",
        particleGeneration=500,      // Amplifie contenu existant
        maxParticleProcessing=1500,  // Traitement algorithmique rapide
        color="#673AB7"
    ];

    TrendingSystem [
        label="Système Tendances",
        geometry="Torus",
        dimensions="{tube: 0.8, tubularSegments: 20, radialSegments: 15}",
        particleGeneration=200,      // Identifie tendances
        maxParticleProcessing=800,
        color="#E91E63"
    ];

    // === FLUX INFLUENCEURS VERS COMMUNAUTÉS ===
    MegaInfluencer -> TechCommunity [
        label="Post Tech Viral",
        maxParticleFlow=300,
        particleSpeed=2.8,           // Diffusion rapide
        color="#4CAF50",
        style="solid"
    ];

    MegaInfluencer -> DesignCommunity [
        label="Contenu Design",
        maxParticleFlow=250,
        particleSpeed=2.5,
        color="#9C27B0",
        style="solid"
    ];

    MegaInfluencer -> GeneralAudience [
        label="Contenu Grand Public",
        maxParticleFlow=600,         // Forte diffusion
        particleSpeed=3.0,           // Très viral
        color="#FFC107",
        style="solid"
    ];

    // === FLUX SPÉCIALISÉS ===
    TechInfluencerA -> TechCommunity [
        label="Expertise Tech A",
        maxParticleFlow=200,
        particleSpeed=2.2,
        color="#2196F3",
        style="dashed"
    ];

    TechInfluencerB -> TechCommunity [
        label="Expertise Tech B",
        maxParticleFlow=180,
        particleSpeed=2.0,
        color="#3F51B5",
        style="dashed"
    ];

    TechInfluencerA -> StartupCommunity [
        label="Croisement Tech-Startup",
        maxParticleFlow=120,
        particleSpeed=1.8,
        color="#795548",
        style="dotted"
    ];

    LifestyleInfluencer -> GeneralAudience [
        label="Lifestyle Viral",
        maxParticleFlow=400,
        particleSpeed=2.9,
        color="#FF9800",
        style="solid"
    ];

    // === PROPAGATION COMMUNAUTAIRE ===
    TechCommunity -> MicroInfluencerA [
        label="Relai Tech",
        maxParticleFlow=150,
        particleSpeed=1.5,
        color="#00BCD4",
        style="dashed"
    ];

    GameCommunity -> MicroInfluencerB [
        label="Relai Gaming",
        maxParticleFlow=180,         // Gaming plus viral
        particleSpeed=1.8,
        color="#607D8B",
        style="dashed"
    ];

    StartupCommunity -> CompanyAccount [
        label="B2B Propagation",
        maxParticleFlow=100,
        particleSpeed=1.3,
        color="#8BC34A",
        style="dotted"
    ];

    // === AMPLIFICATION ALGORITHMIQUE ===
    // Communautés alimentent l'algorithme
    TechCommunity -> RecommendationEngine [
        label="Signal Tech",
        maxParticleFlow=100,
        particleSpeed=1.0,
        color="#673AB7",
        style="dotted"
    ];

    GameCommunity -> RecommendationEngine [
        label="Signal Gaming",
        maxParticleFlow=150,         // Gaming très engageant
        particleSpeed=1.2,
        color="#673AB7",
        style="dotted"
    ];

    DesignCommunity -> RecommendationEngine [
        label="Signal Design",
        maxParticleFlow=80,
        particleSpeed=0.9,
        color="#673AB7",
        style="dotted"
    ];

    // === AMPLIFICATION RETOUR ===
    // Algorithme amplifie vers audience
    RecommendationEngine -> GeneralAudience [
        label="Recommandations",
        maxParticleFlow=800,         // Grande amplification
        particleSpeed=2.5,
        color="#FFC107",
        style="solid"
    ];

    RecommendationEngine -> TrendingSystem [
        label="Feed Tendances",
        maxParticleFlow=300,
        particleSpeed=1.8,
        color="#E91E63",
        style="solid"
    ];

    // === SYSTÈME TENDANCES ===
    TrendingSystem -> MegaInfluencer [
        label="Tendances → Influenceur",
        maxParticleFlow=100,         // Influence mutuelle
        particleSpeed=1.4,
        color="#E91E63",
        style="dashed"
    ];

    TrendingSystem -> GeneralAudience [
        label="Page Tendances",
        maxParticleFlow=400,
        particleSpeed=2.3,
        color="#FFC107",
        style="solid"
    ];

    // === FLUX CROISÉS INTER-COMMUNAUTÉS ===
    TechCommunity -> StartupCommunity [
        label="Tech → Startup",
        maxParticleFlow=60,
        particleSpeed=1.2,
        color="#795548",
        style="dotted"
    ];

    DesignCommunity -> TechCommunity [
        label="Design → Tech",
        maxParticleFlow=50,
        particleSpeed=1.1,
        color="#4CAF50",
        style="dotted"
    ];

    GameCommunity -> TechCommunity [
        label="Gaming → Tech",
        maxParticleFlow=70,          // Overlap tech/gaming
        particleSpeed=1.3,
        color="#4CAF50",
        style="dotted"
    ];

    // === RÉTROACTION ENGAGEMENT ===
    // Audience vers créateurs (likes, shares)
    GeneralAudience -> MegaInfluencer [
        label="Engagement Retour",
        maxParticleFlow=200,         // Feedback d'engagement
        particleSpeed=0.8,           // Plus lent (métrique)
        color="#E91E63",
        style="dotted"
    ];

    GeneralAudience -> LifestyleInfluencer [
        label="Lifestyle Engagement",
        maxParticleFlow=150,
        particleSpeed=0.7,
        color="#FF9800",
        style="dotted"
    ];

    // === FLUX MICRO-INFLUENCEURS ===
    MicroInfluencerA -> GeneralAudience [
        label="Micro Diffusion A",
        maxParticleFlow=60,
        particleSpeed=1.6,
        color="#FFC107",
        style="dashed"
    ];

    MicroInfluencerB -> GeneralAudience [
        label="Micro Diffusion B",
        maxParticleFlow=55,
        particleSpeed=1.5,
        color="#FFC107", 
        style="dashed"
    ];

    CompanyAccount -> GeneralAudience [
        label="Marketing B2C",
        maxParticleFlow=80,
        particleSpeed=1.4,
        color="#FFC107",
        style="solid"
    ];
}

// === PHÉNOMÈNES SOCIAUX MODÉLISÉS ===
// 1. Influence hiérarchique : Méga → Micro → Audience
// 2. Spécialisation thématique : Communautés par centres d'intérêt
// 3. Amplification algorithmique : IA booste contenu viral
// 4. Effet d'accumulation : Goulots créent buzz visible (bloom)
// 5. Boucles de rétroaction : Engagement influence algorithmes
// 6. Croisements communautaires : Diffusion inter-groupes
// 7. Vitesse différentielle : Contenu lifestyle plus rapide que tech
// 8. Système de tendances : Détection et amplification automatique
